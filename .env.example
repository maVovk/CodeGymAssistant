GOOGLE_SERVICE_ACCOUNT_FILE=path/to/your/service-account-credentials.json
TG_TOKEN=TG-BOT-API-TOKEN
SPREADSHEET_ID=your-google-spreadsheet-id-from-url

# Limit exercises shown in the bot: first N columns, or all except exact names (comma-separated).
# If both omitted, bot excludes "Сдано задач", "Разница" by default.
# N_EXERCISES=2
# EXCLUDED_NAMES=Сдано задач,Разница
